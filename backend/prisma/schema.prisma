generator client {
  provider = "prisma-client-js"
  // No output = we use default location for simplicity
}

datasource db {
  provider = "postgresql"
}

model User {
  id            Int      @id @default(autoincrement())
  username      String   @unique
  passwordHash  String
  name          String
  role          Role     @default(STAFF)
  createdAt     DateTime @default(now())
  scans         Scan[]
}

enum Role {
  ADMIN
  STAFF
}

model Animal {
  id          Int      @id @default(autoincrement())
  tagCode     String   @unique
  name        String?
  breed       String
  age         Int?
  status      AnimalStatus @default(ACTIVE)
  healthNotes String?
  qrCodeUrl   String?
  createdAt   DateTime @default(now())
  scans       Scan[]
  donations   Donation[]
}

enum AnimalStatus {
  ACTIVE
  SICK
  MISSING
  DECEASED
}

model Scan {
  id              Int      @id @default(autoincrement())
  animalId        Int
  userId          Int
  scanTimestamp   DateTime @default(now())
  latitude        Float?
  longitude       Float?
  scanMethod      String   @default("QR")
  status          String
  isDuplicate     Boolean  @default(false)
  notes           String?
  animal          Animal   @relation(fields: [animalId], references: [id], onDelete: Cascade)
  user            User     @relation(fields: [userId], references: [id])
}

model Donation {
  id          Int      @id @default(autoincrement())
  donorName   String
  donorEmail  String?
  amount      Float
  billNumber  String   @unique
  animalId    Int?
  createdAt   DateTime @default(now())
  animal      Animal?  @relation(fields: [animalId], references: [id])
}