generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Goshala {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  location  String?
  createdAt DateTime @default(now())
  users     User[]
  animals   Animal[]
}

model User {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  passwordHash String
  name         String
  role         Role     @default(STAFF)
  goshalaId    Int
  createdAt    DateTime @default(now())
  goshala      Goshala  @relation(fields: [goshalaId], references: [id])
  scans        Scan[]
}

enum Role {
  ADMIN
  STAFF
}

model Animal {
  id          Int          @id @default(autoincrement())
  tagCode     String       @unique
  name        String?
  breed       String
  age         Int?
  status      AnimalStatus @default(ACTIVE)
  healthNotes String?
  photoUrl    String?
  qrCodeUrl   String?
  goshalaId   Int
  createdAt   DateTime     @default(now())
  goshala     Goshala      @relation(fields: [goshalaId], references: [id])
  scans       Scan[]
}

enum AnimalStatus {
  ACTIVE
  SICK
  MISSING
  DECEASED
}

model Scan {
  id            Int      @id @default(autoincrement())
  animalId      Int
  userId        Int
  scanTimestamp DateTime @default(now())
  latitude      Float?
  longitude     Float?
  scanMethod    String   @default("QR")
  status        String
  isDuplicate   Boolean  @default(false)
  notes         String?
  animal        Animal   @relation(fields: [animalId], references: [id], onDelete: Cascade)
  user          User     @relation(fields: [userId], references: [id])
}
